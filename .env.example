# Gaming Portal API - Environment Configuration
# Copy this file to .env and modify as needed

# Database connection (required)
# Uses port 5433 to avoid conflict with local PostgreSQL
DATABASE_URL=postgres://portal:portal@localhost:5433/portal_dev

# JWT secret for token signing — REQUIRED. The server refuses to start
# without it. Must be at least 32 bytes. Generate with:
#   openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_base64_48

# Server port (default: 3000)
PORT=3000

# Token expiry configuration (optional, defaults shown)
# ACCESS_TOKEN_EXPIRY_MINUTES=15
# REFRESH_TOKEN_EXPIRY_MINUTES=10080

# Logging level
# Options: error, warn, info, debug, trace
RUST_LOG=portal=debug,tower_http=debug

# CORS allow-list — comma-separated origins. Unset defaults to wildcard with
# a warn log (dev-only). Set explicitly in production.
# PORTAL_CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Per-IP rate limit on /auth/* (login, register, refresh).
# Defaults: burst=20, per_second=5. Tighten in production if brute-force
# attempts show up in logs; loosen if tests on a shared build agent start
# tripping it.
# PORTAL_AUTH_RATE_BURST=20
# PORTAL_AUTH_RATE_PER_SECOND=5
