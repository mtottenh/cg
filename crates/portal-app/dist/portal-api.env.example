# /etc/portal/api.env — loaded by systemd as EnvironmentFile.
#
# Format: KEY=VALUE, one per line. No `export`. Quotes are literal — don't
# wrap values unless they actually contain spaces.
#
# Ansible overwrites this file on deploy from the Vault. Hand-editing on
# the box will be reverted the next time you run the playbook.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Database. For a co-hosted Postgres on the same box, use the Unix socket
# when possible; otherwise localhost:5432.
DATABASE_URL=postgres://portal:CHANGE_ME@localhost:5432/portal_prod

# JWT signing secret. Must be at least 32 bytes — the server hard-fails at
# startup otherwise. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_BYTES_MINIMUM

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------
PORT=3000

# Comma-separated allow-list. Leave empty in prod for no CORS, or set to
# your frontend origin. Wildcard is dev-only.
PORTAL_CORS_ORIGINS=https://portal.example.com

# ---------------------------------------------------------------------------
# Tokens
# ---------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_MINUTES=10080

# ---------------------------------------------------------------------------
# Evidence storage (Linode Object Storage, S3-compatible)
# ---------------------------------------------------------------------------
EVIDENCE_STORAGE=s3
S3_EVIDENCE_BUCKET=portal-evidence
S3_EVIDENCE_REGION=us-east-1
S3_EVIDENCE_PUBLIC_URL=https://portal-evidence.us-east-1.linodeobjects.com
S3_EVIDENCE_ENDPOINT=https://us-east-1.linodeobjects.com
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ---------------------------------------------------------------------------
# CS2 demo service (optional)
# ---------------------------------------------------------------------------
# CS2_DEMO_SERVICE_URL=https://demos.cs210mans.uk

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Use `portal=info` in prod; bump to debug for troubleshooting.
RUST_LOG=portal=info,tower_http=info,sqlx=warn
