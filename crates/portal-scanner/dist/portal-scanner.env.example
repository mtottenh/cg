# /etc/portal/scanner.env — see portal-api env for the general pattern.
#
# Ansible overwrites this from the Vault on deploy.

# Portal API this scanner talks to (localhost when co-hosted).
PORTAL_API_URL=http://127.0.0.1:3000
PORTAL_API_KEY=CHANGE_ME

# Linode Object Storage source bucket for .dem files.
SCANNER_S3_BUCKET=portal-demos
SCANNER_S3_ENDPOINT=https://us-east-1.linodeobjects.com
SCANNER_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# External CS2 demo parser (used to fetch stats for newly cataloged demos).
# Self-hosted portal-demo-stats (recommended) or the external service.
CS2_DEMO_SERVICE_URL=https://demos.cs210mans.uk

SCANNER_POLL_INTERVAL_SECONDS=300
RUST_LOG=portal_scanner=info
